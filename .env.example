# Пароль PostgreSQL
DB_PASS=aps_password

# Bcrypt-хэш пароля администратора (для импорта БД через десктоп-клиент)
# Сгенерировать: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt(12)).decode())"
ADM_PASS_HASH='$2b$12$...'

# JWT-секрет — сгенерировать один раз:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_random_hex_64_chars

# Суперадмин (создаётся при первом запуске если нет пользователей)
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=change_me_on_first_login
