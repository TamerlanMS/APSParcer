# PostgreSQL password
DB_PASS=change_me_strong_password

# bcrypt hash of admin password
# Generate: python3 -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
# Note: in docker-compose.yml $ must be escaped as $$, but in .env file write as-is
ADM_PASS_HASH=$2b$12$examplehashhere

# JWT secret key
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_jwt_secret

# Superadmin credentials
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=change_me_on_first_login

# OpenAI — Phase 2 AI matching (semantic search)
# Get key at: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Pinecone — vector index (Phase 2)
# Get key at: console.pinecone.io → API Keys
# Host URL:   console.pinecone.io → your index → Host
PINECONE_API_KEY=pcsk_...
PINECONE_HOST=https://<index>-<project>.svc.<env>.pinecone.io
